{
  "name": "@4mbl/components",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./.css": "./dist/assets/components.css"
  },
  "types": "dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "license": "MIT",
  "author": "4mbl",
  "homepage": "https://github.com/4mbl/components/#readme",
  "keywords": [
    "react",
    "components"
  ],
  "scripts": {
    "ci": "pnpm run build && pnpm run format:check && pnpm run typecheck && pnpm run lint",
    "dev": "vite",
    "build": "vite build --config vite.config.ts",
    "build:app": "vite build --config vite-app.config.ts",
    "lint": "eslint src/lib",
    "format:check": "prettier --check src/lib",
    "format:write": "prettier --write src/lib",
    "typecheck": "tsc",
    "preview:app": "vite preview",
    "local-release": "changeset version && changeset publish",
    "prepublishOnly": "pnpm run ci"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "glob": "^13.0.6",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "react": "^19",
    "react-dom": "^19",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "unplugin-dts": "^1.0.0",
    "vite": "^8.0.11"
  },
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": "24.x"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
